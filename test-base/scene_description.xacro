<?xml version="1.0"?>
<robot name="env" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="/home/ubuntu/demo/snap-twin/simulation/models/SO101/so101_new_calib.urdf" />

  <link name="world"/>

  <link name="floor">
    <visual>
      <geometry><box size="10 10 0.01"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
  </link>

  <joint name="world_to_floor" type="fixed">
    <parent link="world"/>
    <child link="floor"/>
  </joint>

  <link name="table">
    <visual>
      <geometry><box size="1.2 0.8 0.75"/></geometry>
      <material name="brown"><color rgba="0.6 0.4 0.2 1"/></material>
    </visual>
  </link>

  <joint name="world_to_table" type="fixed">
    <parent link="world"/>
    <child link="table"/>
    <origin xyz="0 0 0.375"/>
  </joint>

  <joint name="table_to_arm" type="fixed">
    <parent link="table"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.375" rpy="0 0 0"/>
  </joint>

</robot>
